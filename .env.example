# Copiá este archivo como `.env` y completá con tus credenciales de TMDB.
# Se obtienen en: https://www.themoviedb.org/settings/api

# Token de acceso de lectura (v4) — usado como Bearer en el header Authorization.
VITE_TMDB_TOKEN=tu_token_de_lectura_aqui

# Clave de API (v3) — alternativa opcional.
VITE_TMDB_API_KEY=tu_api_key_aqui
